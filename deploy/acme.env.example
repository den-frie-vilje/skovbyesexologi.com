# Copy to `acme.env` alongside compose.acme.yml on the NAS.
# NOT committed — holds DNS-provider API creds for DNS-01
# issuance AND DSM creds for the deploy hook.
#
# Path on NAS: /volume1/docker/acme/acme.env
#
# chmod 600 this file after copying.

# ================================================================
# DNS provider — for the DNS-01 challenge on wildcard issuance.
# Example below is Cloudflare. Other providers: see
# https://github.com/acmesh-official/acme.sh/wiki/dnsapi
# ================================================================

# Cloudflare API token with "Zone:DNS:Edit" scoped to
# denfrievilje.dk (the zone that owns *.stage and *.prod).
# Generate at:
#   https://dash.cloudflare.com/profile/api-tokens
CF_Token=
CF_Account_ID=

# ================================================================
# DSM credentials — for the synology_dsm deploy hook that pushes
# renewed certs into DSM's Certificate store via DSM WebAPI.
# ================================================================

# DSM is reachable on the host's loopback thanks to
# `network_mode: host` in compose.acme.yml. If you switched to
# bridge networking with extra_hosts, change this to
# `host.docker.internal`.
SYNO_Hostname=localhost
SYNO_Port=5000
SYNO_Scheme=http

# ⚠️  Do NOT use your primary DSM admin account. Instead create
# a dedicated DSM user that only has the "Certificate" admin
# right, so the blast radius is limited if this file leaks.
#
# DSM → Control Panel → User & Group → Create:
#   Username: acme (or similar)
#   Application permissions: deny all
#   User group: no admin, no groups
# Then Control Panel → User & Group → Advanced → Shared Folder
# and Application permissions: grant only "Certificate" admin.
# If DSM doesn't let you scope to Certificate alone, use an
# admin account but ensure acme.env is chmod 600 + only readable
# by the `deploy` user.
SYNO_Username=
SYNO_Password=

# If you use 2FA on the DSM account, you'll also need:
#   SYNO_DeviceID=<long device ID string>
#   SYNO_DeviceName=acme.sh
# First login interactively once to get the DeviceID (acme.sh
# will print it), then paste it here. Without a 2FA-bypass
# DeviceID, the deploy hook can't log in non-interactively.
