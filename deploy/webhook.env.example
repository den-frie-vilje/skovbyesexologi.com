# Copy to `webhook.env` alongside compose.webhook.yml on the NAS.
# NOT committed — this file holds every secret the deploy script
# reaches for, across every site on the NAS.
#
# Path on NAS: /volume1/docker/webhook/webhook.env
#
# ================================================================
# Naming convention
# ================================================================
# Every var is prefixed by the site's DOMAIN_SAFE:
#   DOMAIN_SAFE = uppercase, dots → underscores
#   e.g. skovbyesexologi.com → SKOVBYESEXOLOGI_COM
#
# Per-site, per-env secrets:
#   <DOMAIN_SAFE>_STAGING_WEBHOOK_SECRET
#   <DOMAIN_SAFE>_PRODUCTION_WEBHOOK_SECRET
#   <DOMAIN_SAFE>_STAGING_CF_API_TOKEN      (optional)
#   <DOMAIN_SAFE>_STAGING_CF_ZONE_ID        (optional)
#   <DOMAIN_SAFE>_PRODUCTION_CF_API_TOKEN   (optional)
#   <DOMAIN_SAFE>_PRODUCTION_CF_ZONE_ID     (optional)
#
# Adding a new site appends two HMAC secrets (mandatory) plus up
# to four CF vars (optional) — and appends two entries to
# hooks.yaml referencing the same var names.
#
# ================================================================
# HMAC webhook secrets
# ================================================================
# Same values also go into each site's GitHub repo as Actions
# secrets (STAGING_WEBHOOK_SECRET, PRODUCTION_WEBHOOK_SECRET — the
# repo scopes them locally, the NAS scopes them per-site).
#
# Generate each with:
#   openssl rand -hex 32
# ================================================================

SKOVBYESEXOLOGI_COM_STAGING_WEBHOOK_SECRET=
SKOVBYESEXOLOGI_COM_PRODUCTION_WEBHOOK_SECRET=

# ================================================================
# Cloudflare cache purge (OPTIONAL, per site, per env)
# ================================================================
# Triggered at the end of a successful deploy — AFTER the new
# container's healthcheck passes.
#
# ⚠️  CF Free-plan purge is whole-zone only (hostname-scoped purge
#     is Enterprise). Only enable when the zone hosts exactly this
#     one site:
#
#     • Production on a dedicated zone (e.g. skovbyesexologi.com
#       as its own zone) → safe. Set the vars below.
#     • Staging on the shared denfrievilje.dk zone (where the
#       wildcard *.stage lives) → DO NOT enable purge. Grey-cloud
#       the *.stage.* wildcard in CF instead so there's no edge
#       cache to purge. Leave STAGING_CF_* blank.
#
# API token permissions: Zone → Cache Purge → Purge, scoped to
# the single zone.
#
# Zone ID: shown on the zone overview page in the CF dashboard,
# right sidebar, "API" section.
# ================================================================

# Staging not configured — recommend grey-clouding
# *.stage.denfrievilje.dk instead. See deploy.sh and DEPLOY.md.
SKOVBYESEXOLOGI_COM_STAGING_CF_API_TOKEN=
SKOVBYESEXOLOGI_COM_STAGING_CF_ZONE_ID=

# Production: dedicated zone, purge_everything is correct.
SKOVBYESEXOLOGI_COM_PRODUCTION_CF_API_TOKEN=
SKOVBYESEXOLOGI_COM_PRODUCTION_CF_ZONE_ID=
