# Copy to `staging.env` alongside compose.staging.yml on the NAS.
# NOT committed — contains the GitHub OAuth App's client secret
# used by the Sveltia auth proxy.
#
# Path on NAS: /volume1/docker/<DOMAIN>/staging/staging.env
# Permissions: 0640 root:deploy (the deploy agent reads this when
# composing the stack; root owns it so a compromised deploy shell
# can't rewrite the OAuth secret).
#
# Scope: this file is PER-SITE (lives under the site's docker
# dir). The agent's per-(site, env) config — domain, branch,
# compose path, optional CF tokens — lives separately at
# /volume1/docker/nas-sites/sites.d/<domain>.<env>.env. Same
# 0640 root:deploy permissions, different content.

# This site's canonical (production) domain.
DOMAIN=skovbyesexologi.com

# Staging origin hostname — this is the site's staging URL
# minus the scheme. MUST use dots-to-dashes in the domain part
# so the LE wildcard *.stage.denfrievilje.dk covers it (LE
# wildcards match exactly ONE label; the raw domain
# "skovbyesexologi.com" contains a dot and would require two
# labels after it, which the wildcard can't reach).
#
# Convention: replace every "." in $DOMAIN with "-".
#   skovbyesexologi.com  → skovbyesexologi-com
#   app.client.com       → app-client-com
#   foo-bar.dk           → foo-bar-dk
#
# Used by the sveltia-auth OAuth proxy as its CSRF ORIGIN.
STAGE_ORIGIN=skovbyesexologi-com.stage.denfrievilje.dk

# Host-side loopback port that DSM's reverse-proxy vhost points
# at. Each new site on the NAS picks the next free pair of
# ports (staging + production). See DEPLOY.md §6 for the live
# allocation — ports in the 80xx range collide with Jitsi on
# this NAS, so allocation starts at 18080.
CADDY_PORT=18080

# GitHub OAuth App credentials. Register at:
#   https://github.com/settings/applications/new
# Callback URL: https://<DOMAIN_DASHED>.stage.denfrievilje.dk/auth/callback
# (dashed form — dots in the domain break the LE wildcard)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
