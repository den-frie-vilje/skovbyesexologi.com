# Copy to `staging.env` alongside compose.staging.yml on the NAS.
# NOT committed — contains the GitHub OAuth App's client secret
# used by the Sveltia auth proxy.
#
# Path on NAS: /volume1/docker/<DOMAIN>/staging/staging.env
#
# Scope: this file is PER-SITE (lives under the site's docker
# dir). Don't confuse with /volume1/docker/webhook/webhook.env
# (shared across every site on the NAS, uses DOMAIN-prefixed
# variable names to keep sites isolated).

# This site's canonical (production) domain. Used by the compose
# file for $${DOMAIN} substitution — specifically to compute the
# OAuth proxy's ORIGIN (which becomes $${DOMAIN}.stage.denfrievilje.dk).
# Only meaningful within this staging.env — the shared webhook's
# script gets the site's domain as a CLI arg, not from env.
DOMAIN=skovbyesexologi.com

# Host-side loopback port that DSM's reverse-proxy vhost points
# at. Each new site on the NAS picks the next free pair of
# ports (staging + production). First site: 8080 / 8081,
# second site: 8082 / 8083, third: 8084 / 8085, etc. Document
# the live allocation in DEPLOY.md §6 so collisions are easy
# to avoid.
CADDY_PORT=8080

# GitHub OAuth App credentials. Register at:
#   https://github.com/settings/applications/new
# Callback URL: https://<DOMAIN>.stage.denfrievilje.dk/auth/callback
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
