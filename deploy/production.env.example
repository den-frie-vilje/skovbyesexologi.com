# Copy to `production.env` alongside compose.production.yml on
# the NAS. Smaller than staging.env — no OAuth secrets here
# because production doesn't run the Sveltia auth proxy (admin
# lives on staging only).
#
# Path on NAS: /volume1/docker/<DOMAIN>/production/production.env
#
# Optional — if you omit this file, compose falls back to the
# default CADDY_PORT=8081 baked into compose.production.yml.
# Still recommended to create it explicitly so port allocation
# is visible per-site.

# Host-side loopback port that DSM's reverse-proxy vhost points
# at for production. Pair this with the site's staging port
# from staging.env — e.g. skovbye uses 18080 (staging) + 18081
# (production) on this NAS; next site uses 18082 + 18083, etc.
CADDY_PORT=18081
