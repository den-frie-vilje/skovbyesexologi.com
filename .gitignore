node_modules/
.svelte-kit/
build/
tools/

# Sveltia bundle is generated by `scripts/copy-sveltia.ts` from
# the pinned version in node_modules/@sveltia/cms — package.json
# + pnpm-lock.yaml are the source of truth, the file in
# static/admin/ is a build artefact.
static/admin/sveltia-cms.js
# Local-only secrets / overrides. The per-mode .env.production,
# .env.staging, .env.development files in this repo contain ONLY
# `PUBLIC_`-prefixed values, which Vite bakes into the public
# client bundle anyway (canonical site URL, GitHub repo name,
# indexing flag). They're NOT secrets — commit them so GH Actions
# builds have them too. `.env` (unscoped) and `.env.*.local` remain
# ignored for developer-specific local overrides.
.env
.env.local
.env.*.local

# Deploy env files — real values (OAuth client secrets, webhook
# HMAC keys, Cloudflare API tokens) live only on the NAS. The
# committed *.env.example files show the shape without values.
deploy/*.env
!deploy/*.env.example
.DS_Store
*.log

# Local source reference photos — not for the public repo.
# The portrait actually served by the site lives at static/img/signe.jpg.
portrait/

# Ad-hoc staging backups (zip dumps taken before risky migrations etc.).
# These can be large and contain committed content — belong outside the
# repo, not in its history.
skovbyesexologi-*.zip
